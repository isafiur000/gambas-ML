Private Sub DefineTextProcessing()

  Dim cmdLst As String[]

  If chkstopword.Value = True Then
    cmdLst = New String[]
    cmdLst.Add("def stopword_removal(tokens):")
    cmdLst.Add("from nltk.corpus import stopwords")
    cmdLst.Add("english_stops = set(stopwords.words('english'))")
    cmdLst.Add("nlp_tokens = [word for word in tokens if word not in english_stops]")
    cmdLst.Add("nlp_tokens = [word for word in nlp_tokens if len(word) >= 3]")
    cmdLst.Add("return nlp_tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  If cmbstemming.Text Then
    cmdLst = New String[]
    cmdLst.Add("def stemming(tokens):")
    Select cmbstemming.Text
      Case "PorterStemmer"
        cmdLst.Add("from nltk.stem import PorterStemmer")
        cmdLst.Add("stemmer = PorterStemmer()")
      Case "LancasterStemmer"
        cmdLst.Add("from nltk.stem import LancasterStemmer")
        cmdLst.Add("stemmer = LancasterStemmer()")
      Case "RegexpStemmer"
        cmdLst.Add("from nltk.stem import RegexpStemmer")
        cmdLst.Add("stemmer = RegexpStemmer('ing')")
      Case "SnowballStemmer"
        cmdLst.Add("from nltk.stem import SnowballStemmer")
        cmdLst.Add("stemmer = SnowballStemmer('english')")
    End Select
    cmdLst.Add("nlp_tokens = [stemmer.stem(word) for word in tokens]")
    cmdLst.Add("return nlp_tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  If cmblemmatize.Text Then
    cmdLst = New String[]
    cmdLst.Add("def lemmatization(tokens):")
    Select cmblemmatize.Text
      Case "WordNetLemmatizer"
        cmdLst.Add("from nltk.stem import WordNetLemmatizer")
        cmdLst.Add("lemmatizer = WordNetLemmatizer()")
    End Select
    cmdLst.Add("nlp_tokens = [lemmatizer.lemmatize(word) for word in tokens]")
    cmdLst.Add("return nlp_tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  If chklowercase.Value = True Then
    cmdLst = New String[]
    cmdLst.Add("def lower_case(tokens):")
    cmdLst.Add("nlp_tokens = [word.lower() for word in tokens]")
    cmdLst.Add("return nlp_tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  If chkrepeatchar.Value = True Then
    cmdLst = New String[]
    cmdLst.Add("def remove_repeatition(tokens):")
    cmdLst.Add("import enchant")
    cmdLst.Add("from replacers import RepeatReplacer")
    cmdLst.Add("replacer = RepeatReplacer()")
    cmdLst.Add("nlp_tokens = [replacer.replace(word) for word in tokens]")
    cmdLst.Add("return nlp_tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  If chkspelcorrect.Value = True Then
    cmdLst = New String[]
    cmdLst.Add("def spelling_correction(tokens):")
    cmdLst.Add("import enchant")
    cmdLst.Add("from replacers import SpellingReplacer")
    cmdLst.Add("replacer = SpellingReplacer()")
    cmdLst.Add("nlp_tokens = [replacer.replace(word) for word in tokens]")
    cmdLst.Add("return nlp_tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

End

Private Sub GetTextProcessing()

  Dim cmdLst As String[]

  cmdLst = New String[]
  cmdLst.Add("def word_process(tokens):")
  If chkstopword.Value = True Then
    cmdLst.Add("tokens = stopword_removal(tokens)")
  Endif
  If cmbstemming.Text Then
    cmdLst.Add("tokens = stemming(tokens)")
  Endif
  If cmblemmatize.Text Then
    cmdLst.Add("tokens = lemmatization(tokens)")
  Endif
  If chklowercase.Value = True Then
    cmdLst.Add("tokens = lower_case(tokens)")
  Endif
  If chkrepeatchar.Value = True Then
    cmdLst.Add("tokens = remove_repeatition(tokens)")
  Endif
  If chkspelcorrect.Value = True Then
    cmdLst.Add("tokens = spelling_correction(tokens)")
  Endif
  cmdLst.Add("return tokens")
  TerminalInputList(cmdLst)
  PressEnterKey()

End

''======================== Text Vectorization ===================
Private Sub TrainVocabulary()

  Dim cmdLst As String[]

  cmdLst = New String[]
  cmdLst.Add("token_corpus = []")
  cmdLst.Add("for col in para_columns:")
  cmdLst.Add("raw_token = para_data[col].apply(lambda tok: word_process(tok)).tolist()")
  cmdLst.Add("for row in raw_token:")
  cmdLst.Add("token_corpus.append(row)")
  TerminalInputList(cmdLst)
  PressEnterKey()
  ' TerminalInput("token_corpus = [sum(row, []) for row in zip(*[orig_data[col] for col in para_columns])]")

End

