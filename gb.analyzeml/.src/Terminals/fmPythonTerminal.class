Private $sType As String
Private $sHead As String[]
Private $sPath As String
Private $hProcess As Process
Private $pyShell As String
Private $isOldVersion As Boolean

Private $Columns As String[]
Private $IndepCol As String[]
Private $vecModels As String[]

Private $paraCol As String[]
Private $numbCol As String[]
Private $catgCol As String[]
Private $defined As Boolean

Private $libprocess As String[]
Private $textProcess As String[]

Private $imgPath As String
Private $catXStr As String
Private $numXStr As String
Private $catYStr As String
Private $numYStr As String
Private $preProcess As String[]

Private $useGensim As Boolean = True

Public Sub _new()

  $pyShell = modSettings.ShowModelsSettingFromFIle("ipython/Shell")
  If $pyShell Then
    $hProcess = TerminalView1.Shell($pyShell)
  Else
    $hProcess = TerminalView1.Shell("ipython3")
  Endif

  cmbmodel.List = GetModelList()
  cmbsplitdata.List = ["X_train.shape", "X_test.shape", "Y_train.shape", "Y_test.shape"]

  cmbnullmethod.List = ["SimpleImputer", "KNNImputer", "IterativeImputer"]
  cmbcatnullmethod.List = ["SimpleImputer", "KNNImputer", "IterativeImputer"]
  cmbnullval.List = ["Null", "Zero"]
  cmbcatnullval.List = ["Null"]
  cmbnullval.Text = "Zero"
  cmbcatnullval.Text = "Null"

  cmbencoding.List = ["OrdinalEncoder", "OneHotEncoder"]
  cmbscaling.List = ["MinMaxScaler", "StandardScaler"]
  cmbscoreaverage.List = ["macro", "micro", "weighted"]

  cmbtokenizer.List = ["word_tokenize", "TreebankWordTokenizer", "WhitespaceTokenizer", "SpaceTokenizer", "WordPunctTokenizer", "ToktokTokenizer", "RegexpTokenizer"]
  cmbstemming.List = ["PorterStemmer", "LancasterStemmer", "RegexpStemmer", "SnowballStemmer"]
  cmblemmatize.List = ["WordNetLemmatizer"]

  $vecModels = ["word2vec", "model2vec", "modernbert"]

End

Public Sub SetFileType(sType As String)

  $sType = sType

End

Public Sub SetHeaderColumns(sHeads As String[])

  $sHead = sHeads

End

Public Sub SetFilePath(sPath As String)

  $sPath = sPath

End

Public Sub Form_Close()

  TerminalInput("exit")

End

Public Sub btndatainstall_Click()

  Dim yList As String[]
  Dim xList As String[]

  yList = New String[]
  yList.Add("python3-full")
  yList.Add("python3-pip")
  modMain.InstallSelectedApplication(xList)

  xList = New String[]
  If $pyShell Then
    xList.Add("numpy")
    xList.Add("pandas")
    xList.Add("scikit-learn")
    xList.Add("matplotlib")
    xList.Add("python-dateutil")
    xList.Add("nltk")
    xList.Add("beautifulsoup4")
    TerminalInput(modMain.PipSelectedApplication(xList))
  Else
    xList.Add("ipython3")
    xList.Add("python3-numpy")
    xList.Add("python3-pandas")
    xList.Add("python3-sklearn")
    xList.Add("python3-matplotlib")
    xList.Add("python3-dateutil")
    xList.Add("python3-nltk")
    xList.Add("python3-bs4")
    modMain.InstallSelectedApplication(xList)
  Endif

End

Private Sub PressEnterKey()

  TerminalView1.Input(Chr$(10))

End

Private Sub TerminalInput(cmd As String)

  TerminalView1.Input(cmd)
  PressEnterKey()
  TerminalView1.EnsureVisible()

End

Private Sub TerminalInputList(cmdLst As String[])

  TerminalView1.Input(cmdLst.Join(gb.NewLine))
  PressEnterKey()
  TerminalView1.EnsureVisible()

End

Private Function GetIpythonOutput(sOutput As String) As String

  Dim cmdLst As New String[]
  Dim sfile As String
  Dim sText As String

  sfile = Temp() & ".txt"
  cmdLst.Add("with open('" & sfile & "', 'w') as f:")
  cmdLst.Add("f.write(" & sOutput & ")")
  TerminalInputList(cmdLst)
  PressEnterKey()

  While (Exist(sfile) = False)
    Wait 0.5
  Wend
  sText = File.Load(sfile)

  Return sText

End

Private Sub GetVersion()

  Dim xver As String

  xver = modMain.DistributionVendor()
  If xver = "Ubuntu22.04" Then
    $isOldVersion = True
  Else
    $isOldVersion = False
  Endif

End

Public Sub Button1_Click()

  If Dialog.SelectDirectory() Then Return
  File.Save(Dialog.Path &/ "ipython" & modMain.GetNowString() & ".txt", TerminalView1.Text)

End

''================================= Load data ===============
Public Sub btndatainit_Click()

  Dim cmdLst As New String[]
  Dim xlibs As String[] = ["import numpy", "import pandas", "import sklearn", "import matplotlib", "import nltk", "import sys"]

  $Columns = New String[]
  $IndepCol = New String[]
  $paraCol = New String[]
  $numbCol = New String[]
  $catgCol = New String[]
  TerminalInputList(xlibs)
  If $useGensim = True Then
    TerminalInput("import gensim")
  Endif
  TerminalInput("sys.path.append('/usr/local/bin/analyzeml')")

  $libprocess = New String[]
  $textProcess = New String[]
  $catXStr = ""
  $numXStr = ""
  $numYStr = ""
  $defined = False

  cmdLst.Add("'numpy version :', numpy.__version__")
  cmdLst.Add("'pandas version :', pandas.__version__")
  cmdLst.Add("'sklearn version :', sklearn.__version__")
  cmdLst.Add("'matplotlib version :', matplotlib.__version__")
  cmdLst.Add("'nltk version :', nltk.__version__")
  If $useGensim = True Then
    cmdLst.Add("'gensim version :', gensim.__version__")
  Endif
  TerminalInputList(cmdLst)
  btndataload.Enabled = True
  Wizard1.ShowButton = False

End

Public Sub btninstmodel_Click()

  Dim xList As String[]

  xList = New String[]
  Select cmbmodel.Text
    Case "XGBoost Regression", "XGBoost Classifier"
      If $pyShell Then
        TerminalInput("pip install xgboost")
      Else
        xList.Add("python3-xgboost")
        modMain.InstallSelectedApplication(xList)
      Endif
    Case "LGBM Classifier", "LGBM Regression"
      If $pyShell Then
        TerminalInput("pip install 'lightgbm[scikit-learn]'")
      Endif
  End Select

End

Public Sub btndataload_Click()

  Dim cmdLst As New String[]
  Dim aHead As String[]
  Dim i As Integer
  Dim xcolm As String

  $Columns = $sHead.Copy()
  aHead = $sHead.Copy()
  For i = 0 To aHead.Count - 1
    aHead[i] = "'" & aHead[i] & "'"
  Next

  If File.Ext($sPath) = "csv" Then
    cmdLst.Add("columns = " & "[" & aHead.Join(", ") & "]")
    If $sType = "CSV" Then
      cmdLst.Add("orig_data = pandas.read_csv(\"" & $sPath & "\", sep = '" & "\\" & "t" & "', names = columns, header = 0)")
    Else
      cmdLst.Add("orig_data = pandas.read_csv(\"" & $sPath & "\", sep = '" & "\\" & "t" & "', names = columns)")
    Endif

  Else
    cmdLst.Add("orig_data = pandas.read_json(\"" & $sPath & "\")")
    cmdLst.Add("orig_data.columns = " & "[" & aHead.Join(", ") & "]")
  Endif
  TerminalInputList(cmdLst)

  For Each xcolm In $Columns
    cmdLst.Add(Subst("orig_data['&1'].mask(orig_data['&1'] == '__', None, inplace=True)", xcolm))
  Next
  cmdLst.Add("orig_data")
  TerminalInputList(cmdLst)
  cmbdependent.List = $Columns

End

Private Sub GetModelList() As String[]

  Dim xlst As String[]

  xlst = New String[]
  If rbregression.Value = True Then
    xlst.Add("Linear Regression")
    xlst.Add("SGD Regression")
    xlst.Add("Ridge Regression")
    xlst.Add("Lasso Regression")
    xlst.Add("ElasticNet Regression")
    xlst.Add("Linear SVR")
    xlst.Add("Nonlinear SVR")
    xlst.Add("DecisionTree Regression")
    xlst.Add("RandomForest Regression")
    xlst.Add("HGBT Regression")
    xlst.Add("LGBM Regression")
    xlst.Add("AdaBoost Regression")
    xlst.Add("XGBoost Regression")
    valtrain.Value = 80
    valtrain.Enabled = True
    pnlregress.Visible = True
    pnlclassif.Visible = False
    pnlunsuper.Visible = False
  Else If rbclass.Value = True Then
    xlst.Add("Dummy Classifier")
    xlst.Add("Logistic Regression")
    xlst.Add("SGD Classifier")
    xlst.Add("KNeighbors Classifier")
    xlst.Add("Linear SVC")
    xlst.Add("Nonlinear SVC")
    xlst.Add("DecisionTree Classifier")
    xlst.Add("RandomForest Classifier")
    xlst.Add("HGBT Classifier")
    xlst.Add("LGBM Classifier")
    xlst.Add("AdaBoost Classifier")
    xlst.Add("XGBoost Classifier")
    valtrain.Value = 80
    valtrain.Enabled = True
    pnlregress.Visible = False
    pnlclassif.Visible = True
    pnlunsuper.Visible = False
  Else If rbunsupervis.Value = True Then
    xlst.Add("KMeans Clustering")
    xlst.Add("DBSCAN")
    xlst.Add("Isolation Forest")
    xlst.Add("Local Outlier Factor")
    valtrain.Value = 100
    valtrain.Enabled = False
    pnlregress.Visible = True
    pnlclassif.Visible = False
    pnlunsuper.Visible = True
  Endif

  Return xlst

End

