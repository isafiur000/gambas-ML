Public Sub btninstallmodel_Click()

  Dim xList As String[]

  If cmbtextvector.Text Then
    xList = New String[]
    Select cmbtextvector.Text
      Case "word2vec", "model2vec"
        If $pyShell Then
          TerminalInput("pip install gensim")
        Else
          xList.Add("python3-gensim")
          modMain.InstallSelectedApplication(xList)
        Endif

      Case "modernbert"
        If $pyShell Then
          TerminalInput("pip install torch torchvision --index-url https://download.pytorch.org/whl/cpu")
          TerminalInput("pip install transformers")
        Else
        Endif
