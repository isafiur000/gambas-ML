Private Sub HideAll()

  pnlone.Visible = False
  pnltwo.Visible = False
  pnlthree.Visible = False
  pnlfour.Visible = False

End

Public Sub cmbmodel_Click()

  Dim xparamLst As String[]

  HideAll()
  Select cmbmodel.Text
    Case "Linear Regression"
      xparamLst = New String[]
    Case "SGD Regression"
      xparamLst = ["random_state:42", "max_iter:1000", "n_iter_no_change:100", "tol:1e-5", "penalty:None", "eta0:0.01"]
    Case "Ridge Regression"
      xparamLst = ["alpha:0.1", "solver:'cholesky'"]
    Case "Lasso Regression"
      xparamLst = ["alpha:0.1"]
    Case "ElasticNet Regression"
      xparamLst = ["alpha:0.1", "l1_ratio:0.5"]
    Case "Logistic Regression"
      xparamLst = ["random_state:42"]
    Case "Linear SVR"
      xparamLst = ["random_state:42", "epsilon:0.5"]
    Case "Nonlinear SVR"
      xparamLst = ["kernel:'poly'", "epsilon:0.1", "degree:2", "C:0.01"]
    Case "DecisionTree Regression"
      xparamLst = ["random_state:42", "max_depth:2"]
    Case "RandomForest Regression"
      xparamLst = ["random_state:42", "n_estimators:100", "max_depth:2"]
    Case "HGBT Regression"
      xparamLst = ["random_state:42", "max_iter:100", "learning_rate:0.1"]
    Case "LGBM Regression"
      xparamLst = ["random_state:42", "n_estimators:100", "learning_rate:0.05"]
    Case "AdaBoost Regression"
      xparamLst = ["random_state:42", "n_estimators:50", "learning_rate:1.0"]
    Case "XGBoost Regression"
      xparamLst = ["random_state:42", "n_estimators:100", "learning_rate:0.1", "max_depth:5"]

    Case "Dummy Classifier"
      xparamLst = New String[]
    Case "SGD Classifier"
      xparamLst = ["random_state:42"]
    Case "KNeighbors Classifier"
      xparamLst = New String[]
    Case "Linear SVC"
      xparamLst = ["random_state:42", "C:1"]
    Case "Nonlinear SVC"
      xparamLst = ["kernel:'poly'", "coef0:1", "degree:3", "C:5"]
    Case "DecisionTree Classifier"
      xparamLst = ["random_state:42", "max_depth:2"]
    Case "RandomForest Classifier"
      xparamLst = ["random_state:42", "n_estimators:100", "max_depth:2"]
    Case "HGBT Classifier"
      xparamLst = ["random_state:42", "max_iter:100", "learning_rate:0.1"]
    Case "LGBM Classifier"
      xparamLst = ["random_state:42", "n_estimators:100", "learning_rate:0.05"]
    Case "AdaBoost Classifier"
      xparamLst = ["random_state:42", "n_estimators:50", "learning_rate:1.0"]
    Case "XGBoost Classifier"
      xparamLst = ["random_state:42", "n_estimators:100", "learning_rate:0.1", "max_depth:5"]

    Case "KMeans Clustering"
      xparamLst = ["random_state:42", "n_clusters:3"]
    Case "DBSCAN"
      xparamLst = ["min_samples:5", "eps:0.05"]
    Case "Isolation Forest"
      xparamLst = ["random_state:42", "contamination:0.05"]
    Case "Local Outlier Factor"
      xparamLst = ["n_neighbors:20"]
  End Select

  ShowHyperParams(xparamLst)

End

Private Sub ShowHyperParams(sParamList As String[])

  Dim sInt As Integer

  sInt = sParamList.Count
  If sInt > 0 Then
    pnlone.Visible = True
    lblmodelone.Text = Split(sParamList[0], ":")[0]
    txtmodelone.Text = Split(sParamList[0], ":")[1]
    chkfirst.Value = True
  Endif
  If sInt > 1 Then
    pnltwo.Visible = True
    lblmodeltwo.Text = Split(sParamList[1], ":")[0]
    txtmodeltwo.Text = Split(sParamList[1], ":")[1]
    chksecond.Value = True
  Endif
  If sInt > 2 Then
    pnlthree.Visible = True
    lblmodelthree.Text = Split(sParamList[2], ":")[0]
    txtmodelthree.Text = Split(sParamList[2], ":")[1]
    chkthird.Value = True
  Endif
  If sInt > 3 Then
    pnlfour.Visible = True
    lblmodelfour.Text = Split(sParamList[3], ":")[0]
    txtmodelfour.Text = Split(sParamList[3], ":")[1]
    chkfour.Value = True
  Endif
  If sInt > 4 Then
    pnlfive.Visible = True
    lblmodelfive.Text = Split(sParamList[4], ":")[0]
    txtmodelfive.Text = Split(sParamList[4], ":")[1]
    chkfive.Value = True
  Endif
  If sInt > 5 Then
    pnlsix.Visible = True
    lblmodelsix.Text = Split(sParamList[5], ":")[0]
    txtmodelsix.Text = Split(sParamList[5], ":")[1]
    chksix.Value = True
  Endif
  If sInt > 6 Then
    pnlseven.Visible = True
    lblmodelseven.Text = Split(sParamList[6], ":")[0]
    txtmodelseven.Text = Split(sParamList[6], ":")[1]
    chkseven.Value = True
  Endif

End

Private Function GetParameterList() As String[]

  Dim sColl As String[]

  sColl = New String[]
  If chkfirst.Value = True Then
    sColl.Add(Trim(lblmodelone.Text) & " = " & Trim(txtmodelone.Text))
  Endif
  If chksecond.Value = True Then
    sColl.Add(Trim(lblmodeltwo.Text) & " = " & Trim(txtmodeltwo.Text))
  Endif
  If chkthird.Value = True Then
    sColl.Add(Trim(lblmodelthree.Text) & " = " & Trim(txtmodelthree.Text))
  Endif
  If chkfour.Value = True Then
    sColl.Add(Trim(lblmodelfour.Text) & " = " & Trim(txtmodelfour.Text))
  Endif
  If chkfive.Value = True Then
    sColl.Add(Trim(lblmodelfive.Text) & " = " & Trim(txtmodelfive.Text))
  Endif
  If chksix.Value = True Then
    sColl.Add(Trim(lblmodelsix.Text) & " = " & Trim(txtmodelsix.Text))
  Endif
  If chkseven.Value = True Then
    sColl.Add(Trim(lblmodelseven.Text) & " = " & Trim(txtmodelseven.Text))
  Endif

  Return sColl

End

Public Sub btnmodeltrain_Click()

  Dim cmdLst As New String[]

  Dim xParams As String
  Dim xPLst As String[]

  xPLst = GetParameterList()
  If xPLst.Count Then
    xParams = xPLst.Join(", ")
  Else
    xParams = ""
  Endif

  If cmbmodel.Text Then
    If txtdeptype.Text = "object" Or If txtdeptype.Text = "str" Then
      If cmbencoding.Text = "OrdinalEncoder" Then
        cmdLst.Add("Y_train = numpy.ravel(Y_train)")
        TerminalInputList(cmdLst)
      Else If cmbencoding.Text = "OneHotEncoder" Then
        Select cmbmodel.Text
          Case "DecisionTree Classifier", "RandomForest Classifier", "HGBT Classifier", "LGBM Classifier", "AdaBoost Classifier", "XGBoost Classifier"
          Case Else
            cmdLst.Add("Y_train = numpy.argmax(Y_train, axis=1)")
        End Select
        TerminalInputList(cmdLst)
      Endif
    Endif

    Inc Application.Busy
    If rbregression.Value = True Then
      Select cmbmodel.Text
        Case "Linear Regression"
          cmdLst.Add("from sklearn.linear_model import LinearRegression")
          cmdLst.Add(Subst("lin_reg = LinearRegression(&1)", xParams))
          cmdLst.Add("lin_reg.fit(X_train, Y_train)")
          cmdLst.Add("lin_reg.intercept_")
          cmdLst.Add("lin_reg.coef_")
        Case "SGD Regression"
          cmdLst.Add("from sklearn.linear_model import SGDRegressor")
          cmdLst.Add(Subst("sgd_reg = SGDRegressor(&1)", xParams))             ''
          cmdLst.Add("sgd_reg.fit(X_train, Y_train.ravel())")
          cmdLst.Add("sgd_reg.intercept_")
          cmdLst.Add("sgd_reg.coef_")
        Case "Ridge Regression"
          cmdLst.Add("from sklearn.linear_model import Ridge")
          cmdLst.Add(Subst("ridge_reg = Ridge(&1)", xParams))
          cmdLst.Add("ridge_reg.fit(X_train, Y_train)")
          cmdLst.Add("ridge_reg.intercept_")
          cmdLst.Add("ridge_reg.coef_")
        Case "Lasso Regression"
          cmdLst.Add("from sklearn.linear_model import Lasso")
          cmdLst.Add(Subst("lasso_reg = Lasso(&1)", xParams))
          cmdLst.Add("lasso_reg.fit(X_train, Y_train)")
          cmdLst.Add("lasso_reg.intercept_")
          cmdLst.Add("lasso_reg.coef_")
        Case "ElasticNet Regression"
          cmdLst.Add("from sklearn.linear_model import ElasticNet")
          cmdLst.Add(Subst("elastic_net = ElasticNet(&1)", xParams))
          cmdLst.Add("elastic_net.fit(X_train, Y_train)")
          cmdLst.Add("elastic_net.intercept_")
          cmdLst.Add("elastic_net.coef_")
        Case "Linear SVR"
          cmdLst.Add("from sklearn.svm import LinearSVR")
          cmdLst.Add(Subst("linsvm_reg = LinearSVR(&1)", xParams))
          cmdLst.Add("linsvm_reg.fit(X_train, Y_train)")
        Case "Nonlinear SVR"
          cmdLst.Add("from sklearn.svm import SVR")
          cmdLst.Add(Subst("svm_reg = SVR(&1)", xParams))
          cmdLst.Add("svm_reg.fit(X_train, Y_train)")
        Case "DecisionTree Regression"
          cmdLst.Add("from sklearn.tree import DecisionTreeRegressor")
          cmdLst.Add(Subst("tree_reg = DecisionTreeRegressor(&1)", xParams))
          cmdLst.Add("tree_reg.fit(X_train, Y_train)")
        Case "RandomForest Regression"
          cmdLst.Add("from sklearn.ensemble import RandomForestRegressor")
          cmdLst.Add(Subst("rf_reg = RandomForestRegressor(&1)", xParams))
          cmdLst.Add("rf_reg.fit(X_train, Y_train)")
        Case "HGBT Regression"
          cmdLst.Add("from sklearn.ensemble import HistGradientBoostingRegressor")
          cmdLst.Add(Subst("hist_reg = HistGradientBoostingRegressor(&1)", xParams))
          cmdLst.Add("hist_reg.fit(X_train, Y_train)")
        Case "LGBM Regression"
          cmdLst.Add("from lightgbm import LGBMRegressor")
          cmdLst.Add(Subst("grad_reg = LGBMRegressor(&1)", xParams))
          cmdLst.Add("grad_reg.fit(X_train, Y_train)")
        Case "AdaBoost Regression"
          cmdLst.Add("from sklearn.ensemble import AdaBoostRegressor")
          cmdLst.Add(Subst("ada_reg = AdaBoostRegressor(&1)", xParams))
          cmdLst.Add("ada_reg.fit(X_train, Y_train)")
        Case "XGBoost Regression"
          cmdLst.Add("from xgboost import XGBRegressor")
          cmdLst.Add(Subst("xgb_reg = XGBRegressor(&1)", xParams))
          cmdLst.Add("xgb_reg.fit(X_train, Y_train)")
      End Select

    Else If rbclass.Value = True Then
      If chkbagging.Value = True Then
        Select cmbmodel.Text
          Case "Logistic Regression"
            cmdLst.Add("from sklearn.ensemble import BaggingClassifier")
            cmdLst.Add("from sklearn.linear_model import LogisticRegression")
            cmdLst.Add(Subst("log_clf = BaggingClassifier(LogisticRegression(&1))", xParams))
            cmdLst.Add("log_clf.fit(X_train, Y_train)")
          Case "SGD Classifier"
            cmdLst.Add("from sklearn.ensemble import BaggingClassifier")
            cmdLst.Add("from sklearn.linear_model import SGDClassifier")
            cmdLst.Add(Subst("sgd_clf = BaggingClassifier(SGDClassifier(&1))", xParams))
            cmdLst.Add("sgd_clf.fit(X_train, Y_train)")
          Case "KNeighbors Classifier"
            cmdLst.Add("from sklearn.ensemble import BaggingClassifier")
            cmdLst.Add("from sklearn.neighbors import KNeighborsClassifier")
            cmdLst.Add(Subst("knn_clf = BaggingClassifier(KNeighborsClassifier(&1))", xParams))
            cmdLst.Add("knn_clf.fit(X_train, Y_train)")
          Case "Linear SVC"
            cmdLst.Add("from sklearn.ensemble import BaggingClassifier")
            cmdLst.Add("from sklearn.svm import LinearSVC")
            cmdLst.Add(Subst("linsvm_clf = BaggingClassifier(LinearSVC(&1))", xParams))
            cmdLst.Add("linsvm_clf.fit(X_train, Y_train)")
          Case "Nonlinear SVC"
            cmdLst.Add("from sklearn.ensemble import BaggingClassifier")
            cmdLst.Add("from sklearn.svm import SVC")
            cmdLst.Add(Subst("svm_clf = BaggingClassifier(SVC(&1))", xParams))
            cmdLst.Add("svm_clf.fit(X_train, Y_train)")
          Case "DecisionTree Classifier"
            cmdLst.Add("from sklearn.ensemble import BaggingClassifier")
            cmdLst.Add("from sklearn.tree import DecisionTreeClassifier")
            cmdLst.Add(Subst("tree_clf = BaggingClassifier(DecisionTreeClassifier(&1))", xParams))
            cmdLst.Add("tree_clf.fit(X_train, Y_train)")
            ' Case "RandomForest Classifier"
            ' Case "HGBT Classifier"
            ' Case "LGBM Classifier"
            ' Case "AdaBoost Classifier"
            ' Case "XGBoost Classifier"
        End Select
      Else
        Select cmbmodel.Text
          Case "Dummy Classifier"
            cmdLst.Add("from sklearn.dummy import DummyClassifier")
            cmdLst.Add(Subst("dummy_clf = DummyClassifier(&1)", xParams))
            cmdLst.Add("dummy_clf.fit(X_train, Y_train)")
          Case "Logistic Regression"
            cmdLst.Add("from sklearn.linear_model import LogisticRegression")
            cmdLst.Add(Subst("log_clf = LogisticRegression(&1)", xParams))
            cmdLst.Add("log_clf.fit(X_train, Y_train)")
          Case "SGD Classifier"
            cmdLst.Add("from sklearn.linear_model import SGDClassifier")
            cmdLst.Add(Subst("sgd_clf = SGDClassifier(&1)", xParams))
            cmdLst.Add("sgd_clf.fit(X_train, Y_train)")
          Case "KNeighbors Classifier"
            cmdLst.Add("from sklearn.neighbors import KNeighborsClassifier")
            cmdLst.Add(Subst("knn_clf = KNeighborsClassifier(&1)", xParams))
            cmdLst.Add("knn_clf.fit(X_train, Y_train)")
          Case "Linear SVC"
            cmdLst.Add("from sklearn.svm import LinearSVC")
            cmdLst.Add(Subst("linsvm_clf = LinearSVC(&1)", xParams))
            cmdLst.Add("linsvm_clf.fit(X_train, Y_train)")
          Case "Nonlinear SVC"
            cmdLst.Add("from sklearn.svm import SVC")
            cmdLst.Add(Subst("svm_clf = SVC(&1)", xParams))
            cmdLst.Add("svm_clf.fit(X_train, Y_train)")
          Case "DecisionTree Classifier"
            cmdLst.Add("from sklearn.tree import DecisionTreeClassifier")
            cmdLst.Add(Subst("tree_clf = DecisionTreeClassifier(&1)", xParams))
            cmdLst.Add("tree_clf.fit(X_train, Y_train)")
          Case "RandomForest Classifier"
            cmdLst.Add("from sklearn.ensemble import RandomForestClassifier")
            cmdLst.Add(Subst("rf_clf = RandomForestClassifier(&1)", xParams))
            cmdLst.Add("rf_clf.fit(X_train, Y_train)")
          Case "HGBT Classifier"
            cmdLst.Add("from sklearn.ensemble import HistGradientBoostingClassifier")
            cmdLst.Add(Subst("hist_clf = HistGradientBoostingClassifier(&1)", xParams))
            cmdLst.Add("hist_clf.fit(X_train, Y_train)")
          Case "LGBM Classifier"
            cmdLst.Add("from lightgbm import LGBMClassifier")
            cmdLst.Add(Subst("grad_clf = LGBMClassifier(&1)", xParams))
            cmdLst.Add("grad_clf.fit(X_train, Y_train)")
          Case "AdaBoost Classifier"
            cmdLst.Add("from sklearn.ensemble import AdaBoostClassifier")
            cmdLst.Add(Subst("ada_clf = AdaBoostClassifier(&1)", xParams))
            cmdLst.Add("ada_clf.fit(X_train, Y_train)")
          Case "XGBoost Classifier"
            cmdLst.Add("from xgboost import XGBClassifier")
            cmdLst.Add(Subst("xgb_clf = XGBClassifier(&1)", xParams))
            cmdLst.Add("xgb_clf.fit(X_train, Y_train)")
        End Select
      Endif

    Else If rbunsupervis.Value = True Then
      Select cmbmodel.Text
        Case "KMeans Clustering"
          cmdLst.Add("from sklearn.cluster import KMeans")
          cmdLst.Add(Subst("kmeans = KMeans(&1)", xParams))
          cmdLst.Add("kmeans.fit(X_train)")
        Case "DBSCAN"
          cmdLst.Add("from sklearn.cluster import DBSCAN")
          cmdLst.Add(Subst("dbscan = DBSCAN(&1)", xParams))
          cmdLst.Add("dbscan.fit(X_train)")
        Case "Isolation Forest"
          cmdLst.Add("from sklearn.ensemble import IsolationForest")
          cmdLst.Add(Subst("iso_forest = IsolationForest(&1)", xParams))
          cmdLst.Add("iso_forest.fit(X_train)")
        Case "Local Outlier Factor"
          cmdLst.Add("from sklearn.neighbors import LocalOutlierFactor")
          cmdLst.Add(Subst("loc_out = LocalOutlierFactor(&1, novelty = True)", xParams))
          cmdLst.Add("loc_out.fit(X_train)")
      End Select

    Endif
    TerminalInputList(cmdLst)
    Dec Application.Busy
    btnevaluate.Enabled = True
  Endif

End

Public Sub btnsavemodel_Click()

  Dim cmdLst As New String[]
  Dim xpath As String

  If cmbmodel.Text Then
    If Dialog.SelectDirectory() Then Return
    xpath = Dialog.Path &/ "model_" & modMain.GetNowString() & ".pkl"

    Inc Application.Busy
    cmdLst.Add("import joblib")
    Select cmbmodel.Text
      Case "Linear Regression"
        cmdLst.Add("joblib.dump(lin_reg, '" & xpath & "')")
      Case "SGD Regression"
        cmdLst.Add("joblib.dump(sgd_reg, '" & xpath & "')")
      Case "Ridge Regression"
        cmdLst.Add("joblib.dump(ridge_reg, '" & xpath & "')")
      Case "Lasso Regression"
        cmdLst.Add("joblib.dump(lasso_reg, '" & xpath & "')")
      Case "ElasticNet Regression"
        cmdLst.Add("joblib.dump(elastic_net, '" & xpath & "')")
      Case "Linear SVR"
        cmdLst.Add("joblib.dump(linsvm_reg, '" & xpath & "')")
      Case "Nonlinear SVR"
        cmdLst.Add("joblib.dump(svm_reg, '" & xpath & "')")
      Case "DecisionTree Regression"
        cmdLst.Add("joblib.dump(tree_reg, '" & xpath & "')")
      Case "RandomForest Regression"
        cmdLst.Add("joblib.dump(rf_reg, '" & xpath & "')")
      Case "HGBT Regression"
        cmdLst.Add("joblib.dump(hist_reg, '" & xpath & "')")
      Case "LGBM Regression"
        cmdLst.Add("joblib.dump(grad_reg, '" & xpath & "')")
      Case "AdaBoost Regression"
        cmdLst.Add("joblib.dump(ada_reg, '" & xpath & "')")
      Case "XGBoost Regression"
        cmdLst.Add("joblib.dump(xgb_reg, '" & xpath & "')")

      Case "Dummy Classifier"
        cmdLst.Add("joblib.dump(dummy_clf, '" & xpath & "')")
      Case "Logistic Regression"
        cmdLst.Add("joblib.dump(log_clf, '" & xpath & "')")
      Case "SGD Classifier"
        cmdLst.Add("joblib.dump(sgd_clf, '" & xpath & "')")
      Case "KNeighbors Classifier"
        cmdLst.Add("joblib.dump(knn_clf, '" & xpath & "')")
      Case "Linear SVC"
        cmdLst.Add("joblib.dump(linsvm_clf, '" & xpath & "')")
      Case "Nonlinear SVC"
        cmdLst.Add("joblib.dump(svm_clf, '" & xpath & "')")
      Case "DecisionTree Classifier"
        cmdLst.Add("joblib.dump(tree_clf, '" & xpath & "')")
      Case "RandomForest Classifier"
        cmdLst.Add("joblib.dump(rf_clf, '" & xpath & "')")
      Case "HGBT Classifier"
        cmdLst.Add("joblib.dump(hist_clf, '" & xpath & "')")
      Case "LGBM Classifier"
        cmdLst.Add("joblib.dump(grad_clf, '" & xpath & "')")
      Case "AdaBoost Classifier"
        cmdLst.Add("joblib.dump(ada_clf, '" & xpath & "')")
      Case "XGBoost Classifier"
        cmdLst.Add("joblib.dump(xgb_clf, '" & xpath & "')")

      Case "KMeans Clustering"
        cmdLst.Add("joblib.dump(kmeans, '" & xpath & "')")
      Case "DBSCAN"
        cmdLst.Add("joblib.dump(dbscan, '" & xpath & "')")
      Case "Isolation Forest"
        cmdLst.Add("joblib.dump(iso_forest, '" & xpath & "')")
      Case "Local Outlier Factor"
        cmdLst.Add("joblib.dump(loc_out, '" & xpath & "')")
    End Select
    TerminalInputList(cmdLst)
    Dec Application.Busy
  Endif

End

Public Sub btnsaveProcess_Click()

  Dim cmdLst As New String[]
  Dim xpath As String

  If cmbmodel.Text Then
    If Dialog.SelectDirectory() Then Return
    xpath = Dialog.Path &/ "processing_" & modMain.GetNowString() & ".pkl"

    Inc Application.Busy
    cmdLst.Add("import joblib")
    If $preProcess.Count Then
      cmdLst.Add("joblib.dump(preprocess_X, '" & xpath & "')")
    Endif
    TerminalInputList(cmdLst)
    Dec Application.Busy
  Endif

End

Public Sub btnevaluate_Click()

  Dim cmdLst As New String[]

  If rbregression.Value = True Then
    Select cmbmodel.Text
      Case "Linear Regression"
        TerminalInput("reg_model = lin_reg")
      Case "SGD Regression"
        TerminalInput("reg_model = sgd_reg")
      Case "Ridge Regression"
        TerminalInput("reg_model = ridge_reg")
      Case "Lasso Regression"
        TerminalInput("reg_model = lasso_reg")
      Case "ElasticNet Regression"
        TerminalInput("reg_model = elastic_net")
      Case "Linear SVR"
        TerminalInput("reg_model = linsvm_reg")
      Case "Nonlinear SVR"
        TerminalInput("reg_model = svm_reg")
      Case "DecisionTree Regression"
        TerminalInput("reg_model = tree_reg")
      Case "RandomForest Regression"
        TerminalInput("reg_model = rf_reg")
      Case "HGBT Regression"
        TerminalInput("reg_model = hist_reg")
      Case "LGBM Regression"
        TerminalInput("reg_model = grad_reg")
      Case "AdaBoost Regression"
        TerminalInput("reg_model = ada_reg")
      Case "XGBoost Regression"
        TerminalInput("reg_model = xgb_reg")
    End Select

    If chkaccuracy.Value = True Then
      TerminalInput("print('Training Score = ', reg_model.score(X_train, Y_train))")
      TerminalInput("print('Testing Score = ', reg_model.score(X_test, Y_test))")
    Endif

  Else If rbclass.Value = True Then
    Select cmbmodel.Text
      Case "Dummy Classifier"
        cmdLst.Add("clf_model = dummy_clf")
      Case "Logistic Regression"
        TerminalInput("clf_model = log_clf")
      Case "SGD Classifier"
        cmdLst.Add("clf_model = sgd_clf")
      Case "KNeighbors Classifier"
        cmdLst.Add("clf_model = knn_clf")
      Case "Linear SVC"
        cmdLst.Add("clf_model = linsvm_clf")
      Case "Nonlinear SVC"
        cmdLst.Add("clf_model = svm_clf")
      Case "DecisionTree Classifier"
        cmdLst.Add("clf_model = tree_clf")
      Case "RandomForest Classifier"
        cmdLst.Add("clf_model = rf_clf")
      Case "HGBT Classifier"
        cmdLst.Add("clf_model = hist_clf")
      Case "LGBM Classifier"
        cmdLst.Add("clf_model = grad_clf")
      Case "AdaBoost Classifier"
        cmdLst.Add("clf_model = ada_clf")
      Case "XGBoost Classifier"
        cmdLst.Add("clf_model = xgb_clf")
    End Select
    cmdLst.Add("from sklearn.model_selection import cross_val_predict")
    cmdLst.Add("y_train_pred = cross_val_predict(clf_model, X_train, Y_train)")

    If chkconfusion.Value = True Then
      cmdLst.Add("from sklearn.metrics import confusion_matrix")
      cmdLst.Add("cm = confusion_matrix(Y_train, y_train_pred)")
      cmdLst.Add("cm")
    Endif
    If chkprecision.Value = True Then
      cmdLst.Add("from sklearn.metrics import precision_score, recall_score")
      cmdLst.Add("from sklearn.metrics import f1_score")
      If Not cmbscoreaverage.Text Then
        cmbscoreaverage.Text = "binary"
      Endif
      If cmbscoreaverage.Text Then
        cmdLst.Add(Subst("print('Precision Score = ', precision_score(Y_train, y_train_pred, average='&1'))", cmbscoreaverage.Text))
        cmdLst.Add(Subst("print('Recall Score = ', recall_score(Y_train, y_train_pred, average='&1'))", cmbscoreaverage.Text))
        cmdLst.Add(Subst("print('F1 Score = ', f1_score(Y_train, y_train_pred, average='&1'))", cmbscoreaverage.Text))
      Endif
    Endif
    TerminalInputList(cmdLst)

  Else If rbunsupervis.Value = True Then
    Select cmbmodel.Text
      Case "KMeans Clustering"
        TerminalInput("unsup_model = kmeans")
      Case "DBSCAN"
        TerminalInput("unsup_model = dbscan")
      Case "Isolation Forest"
        TerminalInput("unsup_model = iso_forest")
      Case "Local Outlier Factor"
        TerminalInput("unsup_model = loc_out")
    End Select

    If chkaccuracy.Value = True Then
      Select cmbmodel.Text
        Case "KMeans Clustering", "DBSCAN"
          cmdLst.Add("from sklearn.metrics import silhouette_score")
          cmdLst.Add("silhouette_score(X_train, unsup_model.labels_)")
          TerminalInputList(cmdLst)
      End Select
    Endif

  Endif

End

Public Sub btnunsupervised_Click()

  Dim cmdLst As New String[]
  Dim xPath As String

  Select cmbmodel.Text
    Case "KMeans Clustering"
      cmdLst.Add("X_Pred = kmeans.predict(X_processed)")
    Case "DBSCAN"
      cmdLst.Add("X_Pred = dbscan.labels_")
    Case "Isolation Forest"
      TerminalInput("X_Pred = iso_forest.predict(X_processed)")
    Case "Local Outlier Factor"
      TerminalInput("X_Pred = loc_out.predict(X_processed)")
  End Select
  cmdLst.Add("X_data['cluster'] = X_Pred.tolist()")
  cmdLst.Add("X_data")
  If chksavefile.Value = True Then
    If Dialog.SelectDirectory() Then Return
    xPath = Dialog.Path &/ modMain.GetNowString() & ".csv"
    cmdLst.Add(Subst("X_data.to_csv('&1', sep='" & "\\" & "t" & "')", xPath))
  Endif
  TerminalInputList(cmdLst)

End

Public Sub btnshowscatterplot_Click()

  Dim cmdLst As New String[]

  Select cmbmodel.Text
    Case "Linear Regression", "SGD Regression", "Ridge Regression", "Lasso Regression", "Lasso Regression", "Logistic Regression"
      $imgPath = Temp() & ".png"
      cmdLst.Add("from matplotlib import pyplot")
      cmdLst.Add("Y_pred_train = reg_model.predict(X_train)")
      cmdLst.Add("pyplot.plot(X_train, Y_pred_train, color = 'blue')")
      cmdLst.Add("pyplot.plot(X_train, Y_train, color = 'red')")
      cmdLst.Add("pyplot.title('Regression Plot')")
      cmdLst.Add("pyplot.savefig('" & $imgPath & "', format='png')")
      TerminalInputList(cmdLst)

    Case "Support Vector Machine"

    Case "DecisionTree Regression", "DecisionTree Classifier"
      cmdLst.Add("from sklearn import tree")
      cmdLst.Add("import graphviz")
      $imgPath = Temp() & ".dot"
      If cmbmodel.Text = "DecisionTree Regression" Then
        cmdLst.Add("tree.plot_tree(tree_reg)")
        cmdLst.Add(Subst("dot_data = tree.export_graphviz(tree_reg, out_file='" & $imgPath & "', feature_names = list(X_data.columns))", $imgPath))
      Else If cmbmodel.Text = "DecisionTree Classifier" Then
        cmdLst.Add("tree.plot_tree(tree_clf)")
        cmdLst.Add(Subst("dot_data = tree.export_graphviz(tree_clf, out_file='" & $imgPath & "', feature_names = list(X_data.columns))", $imgPath))
      Endif
      TerminalInputList(cmdLst)

    Case "RandomForest Regression", "RandomForest Classifier"

  End Select

End

Public Sub btntreeinstal_Click()

  Dim xList As String[]

  xList = New String[]
  If $pyShell Then
    TerminalInput("pip install graphviz")
  Else
    xList.Add("python3-graphviz")
    modMain.InstallSelectedApplication(xList)
  Endif

End

Public Sub btnopen_Click()

  If Exist($imgPath) Then
    Desktop.Open($imgPath)
  Endif

End

Public Sub btnpredict_Click()

  ' Dim amdLst As New String[]
  Dim bmdLst As New String[]
  Dim cmdLst As New String[]
  Dim aVar As Variant[]
  Dim xindep As String
  Dim xjson As String

  aVar = New Variant[]
  For Each xindep In $IndepCol
    aVar.Add([xindep, "String"])
  Next
  If aVar.Count Then
    xjson = GetJSONValue(aVar, True)
    If xjson Then

      bmdLst.Add("import json")
      bmdLst.Add("input_dict = json.loads('" & xjson & "')")
      bmdLst.Add("input_df = pandas.DataFrame(input_dict, index=[0])")
      bmdLst.Add("input_df")
      TerminalInputList(bmdLst)

      If $preProcess.Count Then
        ' amdLst.Add("preprocess_input = make_column_transformer(" & $preProcess.Join(", ") & ")")
        ' amdLst.Add("X_input = preprocess_input.fit_transform(input_df)")
        ' TerminalInputList(amdLst)
        TerminalInput("X_input = preprocess_X.transform(input_df)")
      Else
        TerminalInput("X_input = input_df")
      Endif

      If rbregression.Value = True Then
        Select cmbmodel.Text
          Case "Linear Regression"
            cmdLst.Add("predict_val = lin_reg.predict(X_input)")
          Case "SGD Regression"
            cmdLst.Add("predict_val = sgd_reg.predict(X_input)")
          Case "Ridge Regression"
            cmdLst.Add("predict_val = ridge_reg.predict(X_input)")
          Case "Lasso Regression"
            cmdLst.Add("predict_val = lasso_reg.predict(X_input)")
          Case "ElasticNet Regression"
            cmdLst.Add("predict_val = elastic_net.predict(X_input)")
          Case "Linear SVR"
            cmdLst.Add("predict_val = linsvm_reg.predict(X_input)")
          Case "Nonlinear SVR"
            cmdLst.Add("predict_val = svm_reg.predict(X_input)")
          Case "DecisionTree Regression"
            cmdLst.Add("predict_val = tree_reg.predict(X_input)")
          Case "RandomForest Regression"
            cmdLst.Add("predict_val = rf_reg.predict(X_input)")
          Case "HGBT Regression"
            cmdLst.Add("predict_val = hist_reg.predict(X_input)")
          Case "LGBM Regression"
            cmdLst.Add("predict_val = grad_reg.predict(X_input)")
          Case "AdaBoost Regression"
            cmdLst.Add("predict_val = ada_reg.predict(X_input)")
          Case "XGBoost Regression"
            cmdLst.Add("predict_val = xgb_reg.predict(X_input)")
        End Select
        cmdLst.Add("prediction = predict_val[0]")
        cmdLst.Add("print('Predicted Value = ', prediction)")
        TerminalInputList(cmdLst)
        txtpredict.Text = GetIpythonOutput("f'{prediction}'")

      Else If rbclass.Value = True Then
        Select cmbmodel.Text
          Case "Dummy Classifier"
            cmdLst.Add("predict_val = dummy_clf.predict(X_input)")
          Case "Logistic Regression"
            cmdLst.Add("predict_val = log_clf.predict(X_input)")
          Case "SGD Classifier"
            cmdLst.Add("predict_val = sgd_clf.predict(X_input)")
          Case "KNeighbors Classifier"
            cmdLst.Add("predict_val = knn_clf.predict(X_input)")
          Case "Linear SVC"
            cmdLst.Add("predict_val = linsvm_clf.predict(X_input)")
          Case "Nonlinear SVC"
            cmdLst.Add("predict_val = svm_clf.predict(X_input)")
          Case "DecisionTree Classifier"
            cmdLst.Add("predict_val = tree_clf.predict(X_input)")
          Case "RandomForest Classifier"
            cmdLst.Add("predict_val = rf_clf.predict(X_input)")
          Case "HGBT Classifier"
            cmdLst.Add("predict_val = hist_clf.predict(X_input)")
          Case "LGBM Classifier"
            cmdLst.Add("predict_val = grad_clf.predict(X_input)")
          Case "AdaBoost Classifier"
            cmdLst.Add("predict_val = ada_clf.predict(X_input)")
          Case "XGBoost Classifier"
            cmdLst.Add("predict_val = xgb_clf.predict(X_input)")
        End Select
        cmdLst.Add("prediction = predict_val[0]")
        cmdLst.Add("print('Predicted Value = ', prediction)")
        If $catYStr Then
          cmdLst.Add("predicted_value_label = cat_encode.inverse_transform(prediction.reshape(1, -1))")
          cmdLst.Add("predicted_label = predicted_value_label[0][0]")
          cmdLst.Add("print('Predicted Label = ', predicted_label)")
        Else
          cmdLst.Add("predicted_label = prediction")
        Endif
        TerminalInputList(cmdLst)
        txtpredict.Text = GetIpythonOutput("f'{predicted_label}'")

      Endif

    Endif
  Endif

End
