  btndepset.Text = "Proceed"

End

''======================== Pre Processing ===========================
Public Sub btndropcolumns_Click()

  Dim xList As String[]
  Dim xcmd As String
  Dim i As Integer

  xList = SelectListView("Columns to drop", $Columns, False)
  If xList And If xList.Count Then
    For i = 0 To xList.Count - 1
      $Columns.Remove($Columns.Find(xList[i]))
      xList[i] = "'" & xList[i] & "'"
    Next
    xcmd = "orig_data = orig_data.drop([" & xList.Join(", ") & "], axis = 1)"
    TerminalInput(xcmd)
    cmbdependent.List = $Columns
  Endif

End

Public Sub btnparatype_Click()

  Dim paraLst As String[]
  Dim i As Integer
  Dim j As Integer

  paraLst = SelectListView("Columns with Unstructured Text", $Columns, False)
  If paraLst And If paraLst.Count Then
    $paraCol = paraLst

    For i = 0 To paraLst.Count - 1
      $Columns.Remove($Columns.Find(paraLst[i]))
    Next

    For j = 0 To paraLst.Count - 1
      paraLst[j] = "'" & paraLst[j] & "'"
    Next

    TerminalInput("para_columns = " & "[" & paraLst.Join(", ") & "]")
    cmbdependent.List = $Columns
    lbltextnlp.Font.Bold = True
  Endif

End

Public Sub btnfloadtype_Click()

  Dim xList As String[]
  Dim cmdLst As New String[]
  Dim xcolm As String

  xList = SelectListView("Convert Columns to Float", $Columns, False)
  If xList And If xList.Count Then
    $numbCol = xList
    For Each xcolm In xList
      cmdLst.Add(Subst("orig_data['&1'] = orig_data['&1'].astype(float)", xcolm))
    Next

    TerminalInputList(cmdLst)
    lblchangefloat.Font.Bold = True
  Endif

End

Public Sub btndatetype_Click()

  Dim dateLst As String[]
  Dim cmdLst As New String[]
  Dim xcolm As String

  dateLst = SelectListView("Columns with DateTime Values", $Columns, False)
  If dateLst And If dateLst.Count Then
    cmdLst.Add(Subst("from dateutil import parser"))
    For Each xcolm In dateLst
      cmdLst.Add(Subst("orig_data['&1'] = orig_data['&1'].apply(parser.parse)", xcolm))
    Next

    TerminalInputList(cmdLst)
    lblchangedate.Font.Bold = True
  Endif

End

