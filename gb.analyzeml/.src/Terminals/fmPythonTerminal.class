Private Sub DefineTextVectorization()

  Dim cmdLst As String[]
  Dim xmodel As String

  If cmbtextvector.Text = "word2vec" Then
    TerminalInput("from gensim.models import Word2Vec")
    If chkusetextmodel.Value Then
      xmodel = modSettings.ShowModelsSettingFromFIle(cmbtextvector.Text & "/ModelPath")
      TerminalInput(Subst("nlp_model = Word2Vec.load('&1')", xmodel))
    Else
      TrainVocabulary()
      cmdLst = New String[]
      cmdLst.Add(Subst("nlp_model = Word2Vec(vector_size = &1, window = &2, min_count = &3, sg = &4)", txtvectorsize.Value, txtwindow.Value, txtmincount.Value, txtsg.Value))
      cmdLst.Add("nlp_model.build_vocab(token_corpus)")
      cmdLst.Add("nlp_model.train(token_corpus, total_examples = nlp_model.corpus_count, epochs = 5)")
      TerminalInputList(cmdLst)
      PressEnterKey()
    Endif
    TerminalInput("word_vectors = nlp_model.wv")

  Else If cmbtextvector.Text = "model2vec" Then
    TerminalInput("from model2vec import StaticModel")
    If chkusetextmodel.Value Then
      xmodel = modSettings.ShowModelsSettingFromFIle(cmbtextvector.Text & "/ModelPath")
      TerminalInput(Subst("nlp_model = StaticModel.from_pretrained('&1')", xmodel))
    Endif

  Else If cmbtextvector.Text = "modernbert" Then
    If chkusetextmodel.Value Then
      xmodel = modSettings.ShowModelsSettingFromFIle(cmbtextvector.Text & "/ModelPath")
      cmdLst = New String[]
      cmdLst.Add("import torch")
      cmdLst.Add("from transformers import AutoModel, AutoTokenizer")
      cmdLst.Add(Subst("model_path = '&1'", xmodel))
      cmdLst.Add("nlp_model = AutoModel.from_pretrained(model_path)")
      cmdLst.Add("nlp_tokenizer = AutoTokenizer.from_pretrained(model_path)")
      TerminalInputList(cmdLst)
      PressEnterKey()
    Endif

  Endif

  cmdLst = New String[]
  cmdLst.Add("def vectorize_text(tokens):")
  If cmbtextvector.Text = "word2vec" Then
    cmdLst.Add("word_tokens = word_process(tokens)")
    cmdLst.Add("valid_vectors = [word_vectors[word] for word in word_tokens if word in word_vectors] if tokens else []")
    cmdLst.Add("return numpy.mean(valid_vectors, axis = 0) if valid_vectors else numpy.zeros(word_vectors.vector_size)")
  Else If cmbtextvector.Text = "model2vec" Then
    cmdLst.Add("word_tokens = word_process(tokens)")
    cmdLst.Add("return nlp_model.encode(' '.join(word_tokens))")
  Else If cmbtextvector.Text = "modernbert" Then
    ModelTorchOutput()
    cmdLst.Add("nlp_inputs = nlp_tokenizer(tokens, return_tensors = 'pt', padding = True, truncation = True)")
    cmdLst.Add("nlp_outputs = get_nlp_outputs(nlp_model, nlp_inputs)")
    cmdLst.Add("cls_embedding = nlp_outputs.last_hidden_state.mean(dim = 1).squeeze().numpy()")
    cmdLst.Add("return cls_embedding.tolist()")
  Endif
  TerminalInputList(cmdLst)
  PressEnterKey()

End

Private Sub ModelTorchOutput()

  Dim cmdLst As String[]

  cmdLst = New String[]
  cmdLst.Add("def get_nlp_outputs(nlp_model, nlp_inputs):")
  cmdLst.Add("with torch.no_grad():")
  cmdLst.Add("return nlp_model(**nlp_inputs)")
  TerminalInputList(cmdLst)
  PressEnterKey()

End

Private Sub GetTextVectorization()

  Dim cmdLst As String[]

  cmdLst = New String[]
  cmdLst.Add("all_vectors = []")
  cmdLst.Add("for col in para_columns:")
  cmdLst.Add("vectors = para_data[col].apply(lambda tok: vectorize_text(tok)).tolist()")
  cmdLst.Add("vector_df = pandas.DataFrame(vectors, index = para_data.index)")
  cmdLst.Add("vector_df.columns = [f'{col}_dim_{i}' for i in range(vector_df.shape[1])]")
  cmdLst.Add("all_vectors.append(vector_df)")
  TerminalInputList(cmdLst)
  PressEnterKey()

  TerminalInput("vector_data = pandas.concat(all_vectors, axis=1)")

End

Private Sub TextProcessingPipeline()

  If chktokenize.Value = True Then
    DefineTextProcessing()
    GetTextProcessing()
  Endif

  DefineTextVectorization()
  GetTextVectorization()

End

''==================================== Split data and process =======================
Private Sub GetProcessedDataSet()

  Dim xList As New String[]
  Dim aList As New String[]

  ''for X_data
  GetPreprocessing()
  TerminalInputList($libprocess)
  If $catgCol.Count Then
    TerminalInput($catXStr)
    aList.Add("(cat_pipeline, categ_columns)")
  Endif
  If $numbCol.Count Then
    TerminalInput($numXStr)
    aList.Add("(num_pipeline, num_columns)")
  Endif

  If aList.Count Then
    $preProcess = aList
    xList.Add("preprocess_X = make_column_transformer(" & aList.Join(", ") & ")")
    xList.Add("X_combined = preprocess_X.fit_transform(X_data)")
    TerminalInputList(xList)
  Else
    $preProcess = New String[]
    TerminalInput("X_combined = X_data")
  Endif

  If $paraCol.Count Then
    TextProcessingPipeline()
    TerminalInput("X_processed = numpy.hstack([X_combined, vector_data])")
  Else
    TerminalInput("X_processed = X_combined")
  Endif

  ''Y_data
  If rbunsupervis.Value = True Then
  Else
    If txtdeptype.Text = "object" Or If txtdeptype.Text = "str" Then
      If $catYStr Then
        TerminalInput($catYStr)
        TerminalInput("Y_processed = cat_encode.fit_transform(Y_data.values.reshape(-1, 1))")
      Else
        TerminalInput("Y_processed = Y_data")
      Endif
    Else
      If $numYStr Then
        TerminalInput($numYStr)
        TerminalInput("Y_processed = num_encode.fit_transform(Y_data.values.reshape(-1, 1))")
      Else
        TerminalInput("Y_processed = Y_data")
      Endif
    Endif
  Endif

End

Public Sub btnsplidata_Click()

  Dim cmdLst As New String[]
  Dim trainval As Float

  If rbunsupervis.Value = True Then
    GetProcessedDataSet()
    cmdLst.Add("X_train = X_processed")
    TerminalInputList(cmdLst)
    btnmodeltrain.Enabled = True
    btnsavemodel.Enabled = True
    btnsaveProcess.Enabled = True

  Else
    If cmbdependent.Text Then
      GetProcessedDataSet()
      trainval = valtrain.Value / 100
      cmdLst.Add("from sklearn.model_selection import train_test_split")
      cmdLst.Add(Subst("X_train, X_test, Y_train, Y_test = train_test_split(X_processed, Y_processed, train_size = &1, random_state=42)", trainval))
      TerminalInputList(cmdLst)
      btnmodeltrain.Enabled = True
      btnsavemodel.Enabled = True
      btnsaveProcess.Enabled = True
    Endif

  Endif

End

