Public Sub chktokenize_Click()

  cmbtokenizer.Text = "word_tokenize"

End

Public Sub btntokenize_Click()

  Dim cmdLst As String[]

  If chkcleanpara.Value = True Then
    cmdLst = New String[]
    cmdLst.Add("def clean_html_text(nlp_text):")
    cmdLst.Add("from bs4 import BeautifulSoup")
    cmdLst.Add("soup = BeautifulSoup(nlp_text, 'html.parser')")
    cmdLst.Add("clean_text = soup.get_text()")
    cmdLst.Add("return clean_text")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  If chktokenize.Value = True Then
    cmdLst = New String[]
    cmdLst.Add("def tokenize_text(nlp_text):")
    If cmbtokenizer.Text = "word_tokenize" Then
      cmdLst.Add("from nltk.tokenize import word_tokenize")
      cmdLst.Add("tokens = word_tokenize(nlp_text)")
    Else
      Select cmbtokenizer.Text
        Case "TreebankWordTokenizer"
          cmdLst.Add("from nltk.tokenize import TreebankWordTokenizer")
          cmdLst.Add("tokenizer = TreebankWordTokenizer()")
        Case "WhitespaceTokenizer"
          cmdLst.Add("from nltk.tokenize import WhitespaceTokenizer")
          cmdLst.Add("tokenizer = WhitespaceTokenizer()")
        Case "SpaceTokenizer"
          cmdLst.Add("from nltk.tokenize import SpaceTokenizer")
          cmdLst.Add("tokenizer = SpaceTokenizer()")
        Case "WordPunctTokenizer"
          cmdLst.Add("from nltk.tokenize import WordPunctTokenizer")
          cmdLst.Add("tokenizer = WordPunctTokenizer()")
        Case "ToktokTokenizer"
          cmdLst.Add("from nltk.tokenize import ToktokTokenizer")
          cmdLst.Add("tokenizer = ToktokTokenizer()")
        Case "RegexpTokenizer"
          cmdLst.Add("from nltk.tokenize import RegexpTokenizer")
          cmdLst.Add("tokenizer = RegexpTokenizer('[" & "\\" & "w']+')")
      End Select
      cmdLst.Add("tokens = tokenizer.tokenize(nlp_text)")
    Endif
    cmdLst.Add("return tokens")
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

  cmdLst = New String[]
  cmdLst.Add("for col in para_columns:")
  If chkcleanpara.Value = True Then
    cmdLst.Add("orig_data[col] = orig_data[col].apply(clean_html_text)")
  Endif
  If chktokenize.Value = True Then
    cmdLst.Add("orig_data[col] = orig_data[col].apply(tokenize_text)")
    pnltextprocess.Visible = True
  Else
    pnltextprocess.Visible = False
  Endif
  If chkcleanpara.Value Or If chktokenize.Value Then
    TerminalInputList(cmdLst)
    PressEnterKey()
  Endif

End

Private Sub SelectColumns()

  Dim cmdLst As New String[]
  Dim aList As String[]
  Dim cList As String[]
  Dim i As Integer
  Dim k As Integer

  aList = $numbCol.Copy()
  cList = $catgCol.Copy()

  If aList.Count Then
    For i = 0 To aList.Count - 1
      aList[i] = "'" & aList[i] & "'"
    Next
  Endif
  If cList.Count Then
    For k = 0 To cList.Count - 1
      cList[k] = "'" & cList[k] & "'"
    Next
  Endif

  cmdLst.Add("num_columns = " & "[" & aList.Join(", ") & "]")
  cmdLst.Add("categ_columns = " & "[" & cList.Join(", ") & "]")
  TerminalInputList(cmdLst)

  TerminalInput("num_columns")
  TerminalInput("categ_columns")
  If $paraCol.Count Then
    TerminalInput("para_columns")
  Endif

End

Public Sub btndepset_Click()

  Dim cmdLst As New String[]
  Dim xFields As String[]
  Dim i As Integer
  Dim xList As String[]
  Dim catList As String[]
  Dim col As Integer

  If rbunsupervis.Value = True Then
    $IndepCol = $Columns.Copy()
    SelectColumns()
    TerminalInput("X_data = orig_data")
    Wizard1.ShowButton = True

  Else
    If cmbdependent.Text Then
      $IndepCol = $Columns.Copy()
      $IndepCol.Remove($IndepCol.Find(cmbdependent.Text))

      xList = $IndepCol.Copy()
      If xList And If xList.Count Then
        catList = New String[]
        For col = 0 To xList.Count - 1
          If $paraCol.Exist(xList[col]) = False And If $numbCol.Exist(xList[col]) = False Then
            catList.Add(xList[col])
          Endif
        Next
        $catgCol = catList
      Endif

      If $numbCol.Exist(cmbdependent.Text) Then
        $numbCol.Remove($numbCol.Find(cmbdependent.Text))
      Endif
      If $catgCol.Exist(cmbdependent.Text) Then
        $catgCol.Remove($catgCol.Find(cmbdependent.Text))
      Endif
      SelectColumns()

      cmdLst.Add("Y_data = orig_data['" & cmbdependent.Text & "']")

      xFields = $IndepCol.Copy()
      For i = 0 To xFields.Count - 1
        xFields[i] = "'" & xFields[i] & "'"
      Next
      cmdLst.Add("indep_columns = " & "[" & xFields.Join(", ") & "]")
      cmdLst.Add("X_data = orig_data.loc[:, indep_columns]")
      ' cmdLst.Add("X_data = orig_data.drop(['" & cmbdependent.Text & "'], axis = 1)")

      If $paraCol.Count Then
        cmdLst.Add("para_data = orig_data.loc[:, para_columns]")
      Endif
      TerminalInputList(cmdLst)

      txtdeptype.Text = GetIpythonOutput("str(orig_data.dtypes['" & cmbdependent.Text & "'])")
      GetTextProcessModels()
      Wizard1.ShowButton = True
    Endif

  Endif

End

Private Sub GetTextProcessModels()

  If chktokenize.Value = True Then
    cmbtextvector.List = ["word2vec", "model2vec"]
    cmbtextvector.Text = "word2vec"
    pnlwordvec.Visible = True
    pnlhuburl.Visible = False
    GetNLPParameters()

  Else
    cmbtextvector.List = ["modernbert"]

  Endif

End

